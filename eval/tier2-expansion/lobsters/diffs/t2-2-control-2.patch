diff --git a/app/models/user_standing.rb b/app/models/user_standing.rb
new file mode 100644
index 00000000..428b2938
--- /dev/null
+++ b/app/models/user_standing.rb
@@ -0,0 +1,40 @@
+# typed: false
+
+# Small summary of a user's comment flagging record over a given interval,
+# used by UsersController#standing (HTML and JSON).
+class UserStanding
+  include IntervalHelper
+
+  attr_reader :user, :interval
+
+  def initialize(user, interval_param = "1m")
+    @user = user
+    @interval = time_interval(interval_param)
+  end
+
+  def comments
+    period = interval[:dur].send(interval[:intv].downcase).ago
+    user.comments.where("comments.created_at >= ?", period)
+  end
+
+  def n_comments
+    comments.count
+  end
+
+  def n_flagged_comments
+    comments.where(flags: 1..).count
+  end
+
+  def n_flags
+    comments.sum(:flags)
+  end
+
+  def as_json(*)
+    {
+      username: user.username,
+      n_comments: n_comments,
+      n_flagged_comments: n_flagged_comments,
+      n_flags: n_flags
+    }
+  end
+end
