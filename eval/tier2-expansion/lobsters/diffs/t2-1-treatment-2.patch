+      other_reply = create(:comment, user_id: other_user.id, story_id: story.id,
+        parent_comment_id: comment.id, created_at: 90.days.ago)
+      grandchild_reply = create(:comment, user_id: user.id, story_id: story.id,
+        parent_comment_id: own_reply.id, created_at: 90.days.ago)
+
+      page.driver.post "/comments/#{comment.short_id}/disown", cascade: "1"
